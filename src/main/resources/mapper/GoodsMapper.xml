<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.foodbank.module.resource.goods.mapper.GoodsMapper">

    <select id="selectAvailableGoodsByStation" resultType="com.foodbank.module.resource.goods.entity.Goods">
        SELECT * FROM fb_goods
        WHERE current_station_id = #{stationId}
        AND status = 2
        AND stock > 0
        AND category IN
        <foreach item="cat" collection="categories" open="(" separator="," close=")">
            #{cat}
        </foreach>
        <if test="sysMode == 'WARNING_FREEZE'">
            AND is_emergency_only = 1
        </if>
    </select>

    <select id="getMerchantTotalValue" resultType="java.math.BigDecimal">
        SELECT COALESCE(SUM(estimated_value), 0) FROM fb_goods WHERE merchant_id = #{merchantId}
    </select>

</mapper>
